---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { displayValue } from "../lib/utils";

const allProjects = await getCollection("robots");

const PROJECT_TAGS = new Set(["robots", "software", "print"]);
const projects = allProjects.filter((p) => {
  const tags = p.data.tags;
  if (!tags || tags.length === 0) return true;
  return tags.some((t) => PROJECT_TAGS.has(t));
});

// Newest first. Items without a `created` date sort to the bottom in id order.
const sortedRobots = [...projects].sort((a, b) => {
  const da = a.data.created ?? "";
  const db = b.data.created ?? "";
  if (da && db) return db.localeCompare(da);
  if (da) return -1;
  if (db) return 1;
  return a.id.localeCompare(b.id);
});

const statusBadgeClass = (status: string | undefined) => {
  if (!status) return "";
  if (status === "discontinued" || status === "retired") return "badge-orange-outline";
  return "badge-sky";
};
---

<BaseLayout
  title="Nerdy Layers 3D"
  description="Combat robotics builds, 3D-printed mechanisms, and electronics tinkering by Nerdy Layers 3D."
>
  <header class="mb-8">
    <h1 class="brand-heading text-4xl sm:text-5xl md:text-6xl">Projects</h1>
    <p class="mt-2 text-base sm:text-lg" style="color: var(--color-muted);">
      Combat robotics builds, 3D-printed mechanisms, and electronics tinkering by Nerdy Layers 3D.
    </p>
  </header>

  <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
    {
      sortedRobots.map((robot) => {
        const name = robot.data.robot_name || robot.id;
        const weight = robot.data.weight
          ? `${robot.data.weight}g`
          : robot.data.target_weight
            ? `~${robot.data.target_weight}g`
            : null;
        const isPrint = robot.data.category === "print";
        const isDiscontinued =
          !isPrint && (robot.data.status === "discontinued" || robot.data.status === "retired");

        // For non-print cards, build a short inline metrics strip parallel to
        // the prints strip below: weight + a one-word weapon class + a terse
        // drive summary. Each field degrades cleanly if missing.
        // weapon: pull a recognisable weapon-class keyword from weapon_type
        // (drum/spinner/hammer/wedge/saw/flipper). If weapon_type just says
        // "None" we hide the field entirely.
        let weaponShort: string | null = null;
        if (robot.data.weapon_type && !/^none/i.test(robot.data.weapon_type)) {
          const wm = robot.data.weapon_type.match(
            /\b(drum|spinner|hammer|wedge|saw|flipper|disc|bar|axe|spike)\b/i
          );
          weaponShort = wm
            ? wm[1].charAt(0).toUpperCase() + wm[1].slice(1).toLowerCase()
            : robot.data.weapon_type.split(/[\s(,]/)[0];
        }
        let driveShort: string | null = null;
        if (robot.data.drive_layout) {
          const m = robot.data.drive_layout.match(/\b(\d?WD|tracked)\b/i);
          driveShort = m ? m[1].toUpperCase() : null;
        }
        // Prints link out to MakerWorld (or another source) since they have no
        // dedicated detail page on this site. Everything else opens the local
        // /robots/<id>/ detail page.
        const externalHref = robot.data.makerworld_url || robot.data.source_url;
        const cardHref = isPrint && externalHref
          ? externalHref
          : `/robots/${robot.id}`;
        const isExternal = cardHref.startsWith("http");
        return (
          <a
            href={cardHref}
            target={isExternal ? "_blank" : undefined}
            rel={isExternal ? "noopener noreferrer" : undefined}
            class={`group block overflow-hidden rounded-xl border transition-colors hover:[border-color:var(--color-accent)] ${
              isDiscontinued ? "opacity-65 hover:opacity-100" : ""
            }`}
            style="background: var(--color-surface); border-color: var(--color-border);"
          >
            <div
              class="aspect-[16/10] w-full overflow-hidden border-b"
              style="background: var(--color-bg-deep); border-color: var(--color-border);"
            >
              {robot.data.cover ? (
                <img
                  src={`/assets/${robot.data.cover}`}
                  alt={`${name} cover`}
                  loading="lazy"
                  class="h-full w-full object-contain transition-transform duration-300 group-hover:scale-105"
                />
              ) : (
                <div class="flex h-full w-full items-center justify-center text-5xl font-bold" style="color: var(--color-muted); font-family: var(--font-display);">
                  {name.slice(0, 1).toUpperCase()}
                </div>
              )}
            </div>

            <div class="p-4 sm:p-5">
              <div class="mb-3 flex flex-wrap items-center gap-2">
                <span class="badge badge-amber">{robot.data.category || "robot"}</span>
                {robot.data.status && !isPrint && (
                  <span class={`badge ${statusBadgeClass(robot.data.status)}`}>
                    {robot.data.status}
                  </span>
                )}
              </div>

              <h2 class="brand-heading mb-1 text-xl">{name}</h2>
              {robot.data.concept && (
                <p class="mb-3 text-sm italic" style="color: var(--color-muted);">
                  {robot.data.concept}
                </p>
              )}

              {robot.data.concept && (isPrint || weight || weaponShort || driveShort) && <div class="my-3 border-t" style="border-color: var(--color-border);" />}

              {isPrint ? (
                <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-xs" style="color: var(--color-muted);">
                  {robot.data.mw_downloads != null && (
                    <span>⬇ <strong style="color: var(--color-text);">{robot.data.mw_downloads}</strong> dl</span>
                  )}
                  {robot.data.mw_prints != null && (
                    <span>🖨 <strong style="color: var(--color-text);">{robot.data.mw_prints}</strong> prints</span>
                  )}
                  {robot.data.mw_likes != null && (
                    <span>👍 <strong style="color: var(--color-text);">{robot.data.mw_likes}</strong></span>
                  )}
                  {robot.data.mw_boosts != null && (
                    <span>⚡ <strong style="color: var(--color-text);">{robot.data.mw_boosts}</strong></span>
                  )}
                  {robot.data.makerworld_url && (
                    <span class="ml-auto" style="color: var(--color-link);">MakerWorld ↗</span>
                  )}
                  {!robot.data.makerworld_url && robot.data.source_url && (
                    <span class="ml-auto" style="color: var(--color-link);">Instagram ↗</span>
                  )}
                </div>
              ) : (weight || weaponShort || driveShort) && (
                <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-xs" style="color: var(--color-muted);">
                  {weight && (
                    <span>⚖ <strong style="color: var(--color-text);">{weight}</strong></span>
                  )}
                  {weaponShort && (
                    <span>⚡ <strong style="color: var(--color-text);">{weaponShort}</strong></span>
                  )}
                  {driveShort && (
                    <span>⚙ <strong style="color: var(--color-text);">{driveShort}</strong></span>
                  )}
                </div>
              )}

              {(robot.data.predecessor || robot.data.successor) && (
                <div
                  class="mt-3 flex flex-wrap items-center justify-between gap-2 border-t pt-2 text-xs italic"
                  style="color: var(--color-muted); border-color: var(--color-border); border-style: dashed;"
                >
                  {robot.data.predecessor && (
                    <span>← {displayValue(robot.data.predecessor)}</span>
                  )}
                  {robot.data.successor && (
                    <span>{displayValue(robot.data.successor)} →</span>
                  )}
                </div>
              )}
            </div>
          </a>
        );
      })
    }
  </div>
</BaseLayout>
