---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { displayValue } from "../lib/utils";

const allProjects = await getCollection("robots");

const PROJECT_TAGS = new Set(["robots", "software"]);
const projects = allProjects.filter((p) => {
  const tags = p.data.tags;
  if (!tags || tags.length === 0) return true;
  return tags.some((t) => PROJECT_TAGS.has(t));
});

const statusOrder: Record<string, number> = {
  "in-development": 0,
  active: 1,
  research: 2,
  retired: 3,
  discontinued: 4,
};

const sortedRobots = [...projects].sort((a, b) => {
  const sa = statusOrder[a.data.status ?? ""] ?? 1;
  const sb = statusOrder[b.data.status ?? ""] ?? 1;
  if (sa !== sb) return sa - sb;
  return (a.data.robot_name || a.id).localeCompare(b.data.robot_name || b.id);
});

const statusBadgeClass = (status: string | undefined) => {
  if (!status) return "";
  if (status === "discontinued" || status === "retired") return "badge-orange-outline";
  return "badge-sky";
};
---

<BaseLayout
  title="Nerdy Layers 3D"
  description="Combat robotics builds, 3D-printed mechanisms, and electronics tinkering by Nerdy Layers 3D."
>
  <header class="mb-8">
    <h1 class="brand-heading text-4xl sm:text-5xl md:text-6xl">Projects</h1>
    <p class="mt-2 text-base sm:text-lg" style="color: var(--color-muted);">
      Combat robotics builds, 3D-printed mechanisms, and electronics tinkering by Nerdy Layers 3D.
    </p>
  </header>

  <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
    {
      sortedRobots.map((robot) => {
        const name = robot.data.robot_name || robot.id;
        const weight = robot.data.weight
          ? `${robot.data.weight}g`
          : robot.data.target_weight
            ? `~${robot.data.target_weight}g`
            : null;
        const isDiscontinued =
          robot.data.status === "discontinued" || robot.data.status === "retired";
        return (
          <a
            href={`/robots/${robot.id}`}
            class={`group block overflow-hidden rounded-xl border transition-colors hover:[border-color:var(--color-accent)] ${
              isDiscontinued ? "opacity-65 hover:opacity-100" : ""
            }`}
            style="background: var(--color-surface); border-color: var(--color-border);"
          >
            <div
              class="aspect-[16/10] w-full overflow-hidden border-b"
              style="background: var(--color-bg-deep); border-color: var(--color-border);"
            >
              {robot.data.cover ? (
                <img
                  src={`/assets/${robot.data.cover}`}
                  alt={`${name} cover`}
                  loading="lazy"
                  class="h-full w-full object-contain transition-transform duration-300 group-hover:scale-105"
                />
              ) : (
                <div class="flex h-full w-full items-center justify-center text-5xl font-bold" style="color: var(--color-muted); font-family: var(--font-display);">
                  {name.slice(0, 1).toUpperCase()}
                </div>
              )}
            </div>

            <div class="p-4 sm:p-5">
              <div class="mb-3 flex flex-wrap items-center gap-2">
                <span class="badge badge-amber">{robot.data.category || "robot"}</span>
                {robot.data.status && (
                  <span class={`badge ${statusBadgeClass(robot.data.status)}`}>
                    {robot.data.status}
                  </span>
                )}
                {weight && (
                  <span class="ml-auto text-sm font-semibold" style="color: var(--color-muted);">
                    {weight}
                  </span>
                )}
              </div>

              <h2 class="brand-heading mb-1 text-xl">{name}</h2>
              {robot.data.concept && (
                <p class="mb-3 text-sm italic" style="color: var(--color-muted);">
                  {robot.data.concept}
                </p>
              )}

              {robot.data.concept && <div class="my-3 border-t" style="border-color: var(--color-border);" />}

              <dl class="space-y-1.5 text-sm">
                {robot.data.weapon_type && (
                  <div class="flex items-baseline gap-3">
                    <dt class="shrink-0 whitespace-nowrap" style="color: var(--color-muted);">Weapon</dt>
                    <dd class="ml-auto text-right font-medium" style="overflow-wrap: anywhere;">
                      {robot.data.weapon_type}
                    </dd>
                  </div>
                )}
                {robot.data.weapon_motor && (
                  <div class="flex items-baseline gap-3">
                    <dt class="shrink-0 whitespace-nowrap" style="color: var(--color-muted);">Motor</dt>
                    <dd class="ml-auto text-right font-medium" style="overflow-wrap: anywhere;">
                      {robot.data.weapon_motor}
                    </dd>
                  </div>
                )}
                {robot.data.drive_motors && (
                  <div class="flex items-baseline gap-3">
                    <dt class="shrink-0 whitespace-nowrap" style="color: var(--color-muted);">Drive</dt>
                    <dd class="ml-auto text-right font-medium" style="overflow-wrap: anywhere;">
                      {displayValue(robot.data.drive_motors)}
                    </dd>
                  </div>
                )}
              </dl>

              {(robot.data.predecessor || robot.data.successor) && (
                <div
                  class="mt-3 flex flex-wrap items-center justify-between gap-2 border-t pt-2 text-xs italic"
                  style="color: var(--color-muted); border-color: var(--color-border); border-style: dashed;"
                >
                  {robot.data.predecessor && (
                    <span>← {displayValue(robot.data.predecessor)}</span>
                  )}
                  {robot.data.successor && (
                    <span>{displayValue(robot.data.successor)} →</span>
                  )}
                </div>
              )}
            </div>
          </a>
        );
      })
    }
  </div>
</BaseLayout>
