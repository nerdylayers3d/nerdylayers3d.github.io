---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const allProjects = await getCollection("robots");

const PROJECT_TAGS = new Set(["robots", "software", "print"]);
const projects = allProjects.filter((p) => {
  const tags = p.data.tags;
  if (!tags || tags.length === 0) return true;
  return tags.some((t) => PROJECT_TAGS.has(t));
});

// Newest first. Items without a `created` date sort to the bottom in id order.
const sortedRobots = [...projects].sort((a, b) => {
  const da = a.data.created ?? "";
  const db = b.data.created ?? "";
  if (da && db) return db.localeCompare(da);
  if (da) return -1;
  if (db) return 1;
  return a.id.localeCompare(b.id);
});

// Build-time timestamp shown in the Active Builds header as "Last update:".
// Astro is a static-site generator, so this is evaluated once at build time
// and baked into the HTML — refreshes when you redeploy.
const buildDate = new Date().toISOString().slice(0, 10);

// Bento layout: the first four cards get wide spans (8/4 then 5/7), the rest
// fall back to uniform 4-col tiles on desktop. Mobile collapses to one column.
const colSpan = (i: number): string => {
  if (i === 0) return "md:col-span-8";
  if (i === 1) return "md:col-span-4";
  if (i === 2) return "md:col-span-5";
  if (i === 3) return "md:col-span-7";
  return "md:col-span-4";
};

const statusBadgeClass = (status: string | undefined) => {
  if (!status) return "";
  if (status === "discontinued" || status === "retired") return "badge-orange-outline";
  return "badge-sky";
};
---

<BaseLayout
  title="Nerdy Layers 3D"
  description="I build combat robots and 3D-printed things. Sometimes they work."
>
  {/* Hero */}
  <header class="mx-auto max-w-7xl px-4 py-16 text-center sm:px-8 sm:py-24">
    <h1 class="brand-heading text-5xl leading-[1.05] tracking-tight sm:text-6xl md:text-7xl">
      Combat Robotics &amp;
      <span style="color: var(--color-accent-strong);">3D Printing</span>
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-base sm:text-lg" style="color: var(--color-muted);">
      I build combat robots and 3D-printed things. Sometimes they work.
    </p>
    <div class="mt-10 flex flex-wrap justify-center gap-3 sm:gap-4">
      <a href="#projects" class="btn-primary">
        View Projects →
      </a>
      <a
        href="https://makerworld.com/en/@nerdylayers3d"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-ghost"
      >
        MakerWorld ↗
      </a>
    </div>
  </header>

  {/* Projects grid */}
  <section id="projects" class="mx-auto max-w-7xl px-4 pb-20 sm:px-8">
    <div class="mb-10 flex items-end justify-between">
      <div>
        <h2 class="brand-heading text-3xl sm:text-4xl">Active Builds</h2>
        <p class="mt-1 text-sm" style="color: var(--color-muted);">
          Documented engineering logs and downloadable models.
        </p>
      </div>
      <span class="label-technical hidden text-xs sm:inline" style="color: var(--color-accent);">
        Last update: {buildDate}
      </span>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-12">
      {
        sortedRobots.map((robot, i) => {
          const name = robot.data.robot_name || robot.id;
          const weight = robot.data.weight
            ? `${robot.data.weight}g`
            : robot.data.target_weight
              ? `~${robot.data.target_weight}g`
              : null;
          const isPrint = robot.data.category === "print";
          const isDiscontinued =
            !isPrint && (robot.data.status === "discontinued" || robot.data.status === "retired");
          const isActive =
            !isPrint && (robot.data.status === "in-development" || robot.data.status === "active");

          const externalHref = robot.data.makerworld_url || robot.data.source_url;
          const cardHref = isPrint && externalHref
            ? externalHref
            : `/robots/${robot.id}`;
          const isExternal = cardHref.startsWith("http");

          // Robot/software cards: extract a short weapon class + drive label
          // for the inline tech strip.
          let weaponShort: string | null = null;
          if (robot.data.weapon_type && !/^none/i.test(robot.data.weapon_type)) {
            const wm = robot.data.weapon_type.match(
              /\b(drum|spinner|hammer|wedge|saw|flipper|disc|bar|axe|spike)\b/i
            );
            weaponShort = wm
              ? wm[1].charAt(0).toUpperCase() + wm[1].slice(1).toLowerCase()
              : robot.data.weapon_type.split(/[\s(,]/)[0];
          }
          let driveShort: string | null = null;
          if (robot.data.drive_layout) {
            const m = robot.data.drive_layout.match(/\b(\d?WD|tracked)\b/i);
            driveShort = m ? m[1].toUpperCase() : null;
          }

          const span = colSpan(i);
          const isWide = i === 0 || i === 3;

          return (
            <a
              href={cardHref}
              target={isExternal ? "_blank" : undefined}
              rel={isExternal ? "noopener noreferrer" : undefined}
              class={`group card-glow relative flex flex-col overflow-hidden rounded-xl border ${span} ${isDiscontinued ? "opacity-70 hover:opacity-100" : ""}`}
              style="background: var(--color-surface); border-color: var(--color-border);"
            >
              <div
                class={`w-full overflow-hidden ${isWide ? "aspect-[16/9]" : "aspect-[16/10]"}`}
                style="background: var(--color-bg-deep);"
              >
                {robot.data.cover ? (
                  <img
                    src={`/assets/${robot.data.cover}`}
                    alt={`${name} cover`}
                    loading="lazy"
                    class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                  />
                ) : (
                  <div
                    class="flex h-full w-full items-center justify-center text-6xl font-bold"
                    style="color: var(--color-muted); font-family: var(--font-display);"
                  >
                    {name.slice(0, 1).toUpperCase()}
                  </div>
                )}
              </div>

              <div class={`flex flex-1 flex-col ${isWide ? "p-6 sm:p-8" : "p-5 sm:p-6"}`}>
                {/* Title + category icon row */}
                <div class="mb-3 flex items-start justify-between gap-3">
                  <h3
                    class="brand-heading text-xl sm:text-2xl"
                    style="color: var(--color-accent);"
                  >
                    {name}
                  </h3>
                  {isActive && (
                    <span class="label-technical mt-1 flex shrink-0 items-center gap-1.5 text-[10px]" style="color: var(--color-accent);">
                      <span class="status-pulse h-1.5 w-1.5 rounded-full" style="background: var(--color-accent);"></span>
                      LIVE
                    </span>
                  )}
                </div>

                {/* Category + status chips */}
                <div class="mb-3 flex flex-wrap items-center gap-2">
                  <span class="badge badge-amber">{robot.data.category || "robot"}</span>
                  {robot.data.status && !isPrint && (
                    <span class={`badge ${statusBadgeClass(robot.data.status)}`}>
                      {robot.data.status}
                    </span>
                  )}
                </div>

                {robot.data.concept && (
                  <p class="mb-4 text-sm" style="color: var(--color-muted);">
                    {robot.data.concept}
                  </p>
                )}

                {/* Stats block — Stitch-style 4-up grid of mono labels on wide
                    cards, inline strip on small. Sits at the bottom via mt-auto. */}
                {isPrint ? (
                  <div
                    class="mt-auto grid grid-cols-2 gap-3 rounded-lg p-3 sm:grid-cols-4"
                    style="background: var(--color-bg-deep);"
                  >
                    {robot.data.mw_downloads != null && (
                      <div>
                        <span class="label-technical block text-[10px]" style="color: var(--color-muted);">
                          Downloads
                        </span>
                        <span class="label-technical text-xs" style="color: var(--color-text);">
                          {robot.data.mw_downloads}
                        </span>
                      </div>
                    )}
                    {robot.data.mw_prints != null && (
                      <div>
                        <span class="label-technical block text-[10px]" style="color: var(--color-muted);">
                          Prints
                        </span>
                        <span class="label-technical text-xs" style="color: var(--color-text);">
                          {robot.data.mw_prints}
                        </span>
                      </div>
                    )}
                    {robot.data.mw_likes != null && (
                      <div>
                        <span class="label-technical block text-[10px]" style="color: var(--color-muted);">
                          Likes
                        </span>
                        <span class="label-technical text-xs" style="color: var(--color-text);">
                          {robot.data.mw_likes}
                        </span>
                      </div>
                    )}
                    {robot.data.mw_boosts != null && (
                      <div>
                        <span class="label-technical block text-[10px]" style="color: var(--color-muted);">
                          Boosts
                        </span>
                        <span class="label-technical text-xs" style="color: var(--color-text);">
                          {robot.data.mw_boosts}
                        </span>
                      </div>
                    )}
                  </div>
                ) : (
                  (weight || weaponShort || driveShort) && (
                    <div
                      class="mt-auto grid grid-cols-3 gap-3 rounded-lg p-3"
                      style="background: var(--color-bg-deep);"
                    >
                      <div>
                        <span class="label-technical block text-[10px]" style="color: var(--color-muted);">
                          Weight
                        </span>
                        <span class="label-technical text-xs" style="color: var(--color-text);">
                          {weight || "—"}
                        </span>
                      </div>
                      <div>
                        <span class="label-technical block text-[10px]" style="color: var(--color-muted);">
                          Weapon
                        </span>
                        <span class="label-technical text-xs" style="color: var(--color-text);">
                          {weaponShort || "—"}
                        </span>
                      </div>
                      <div>
                        <span class="label-technical block text-[10px]" style="color: var(--color-muted);">
                          Drive
                        </span>
                        <span class="label-technical text-xs" style="color: var(--color-text);">
                          {driveShort || "—"}
                        </span>
                      </div>
                    </div>
                  )
                )}

                {/* External-source footer link for prints */}
                {isPrint && (
                  <div class="mt-3 flex items-center justify-end">
                    <span class="label-technical text-[10px]" style="color: var(--color-accent);">
                      {robot.data.makerworld_url ? "MakerWorld ↗" : "Instagram ↗"}
                    </span>
                  </div>
                )}
              </div>
            </a>
          );
        })
      }
    </div>
  </section>
</BaseLayout>
