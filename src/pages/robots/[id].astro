---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { resolveWikiLink, resolveRobotLink, displayValue } from "../../lib/utils";

export async function getStaticPaths() {
  const robots = await getCollection("robots");
  return robots.map((robot) => ({
    params: { id: robot.id },
    props: { robot },
  }));
}

const { robot } = Astro.props;
const { Content } = await render(robot);
const data = robot.data;

const name = data.robot_name || robot.id;
const isPrint = data.category === "print";

const weightDisplay = data.weight
  ? `${data.weight}g`
  : data.target_weight
    ? `${data.target_weight}g (target)`
    : data.weight_note
      ? data.weight_note
      : undefined;

// Spec list — only includes fields the entry actually has. Each row has a
// short uppercase mono label + the value; some values are links to other
// pages on the site (wikilink-resolved).
const specs = [
  { label: "Status", value: data.status },
  { label: "Category", value: data.category },
  { label: "Weight", value: weightDisplay },
  { label: "Predecessor", value: data.predecessor, link: resolveRobotLink(data.predecessor) },
  { label: "Successor", value: data.successor, link: resolveRobotLink(data.successor) },
  { label: "Weapon Type", value: data.weapon_type },
  { label: "Weapon Mass", value: data.weapon_mass },
  { label: "Weapon Hardware", value: data.weapon_hardware },
  { label: "Weapon Motor", value: data.weapon_motor },
  { label: "Weapon Drive", value: data.weapon_drive },
  { label: "Drum OD", value: data.weapon_drum_od },
  { label: "Drum Length", value: data.weapon_drum_length },
  { label: "Drum Bore", value: data.weapon_drum_bore },
  { label: "Drum Shaft", value: data.weapon_drum_shaft },
  { label: "Drum Bearings", value: data.weapon_drum_bearings },
  { label: "Tooth Fastener", value: data.weapon_tooth_fastener },
  { label: "Battery", value: data.battery_voltage, link: resolveWikiLink(data.battery_voltage) },
  { label: "Gearing", value: data.gearing },
  { label: "Drive Motors", value: data.drive_motors, link: resolveWikiLink(data.drive_motors) },
  { label: "Drive Layout", value: data.drive_layout },
  { label: "Wheel Pulley", value: data.wheel_pulley_diameter },
  { label: "Wheels", value: data.wheels },
  { label: "Armor", value: data.armor_material },
  { label: "Wedge", value: data.wedge_specs },
  { label: "Receiver", value: data.receiver, link: resolveWikiLink(data.receiver) },
].filter((s) => s.value);

// Prints have their own MakerWorld metrics — surface those as the spec panel
// instead of robot tech specs.
const printMetrics = [
  { label: "Downloads", value: data.mw_downloads },
  { label: "Prints", value: data.mw_prints },
  { label: "Likes", value: data.mw_likes },
  { label: "Boosts", value: data.mw_boosts },
  { label: "Rating", value: data.mw_rating },
  { label: "Category", value: data.makerworld_category },
  { label: "Released", value: data.created },
].filter((s) => s.value != null);

const statusBadgeClass = (status: string | undefined) => {
  if (!status) return "";
  if (status === "discontinued" || status === "retired") return "badge-orange-outline";
  return "badge-sky";
};
const isActive = !isPrint && (data.status === "in-development" || data.status === "active");
---

<BaseLayout
  title={`${name} — Nerdy Layers 3D`}
  description={data.concept || `${name} — a Nerdy Layers 3D project.`}
  image={data.cover}
>
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-8 sm:py-12">
    <a
      href="/"
      class="label-technical mb-6 inline-flex items-center gap-1 text-xs"
      style="color: var(--color-muted);"
    >
      ← Back to projects
    </a>

    {/* Hero header with cover */}
    <header class="mb-10">
      <div class="mb-4 flex flex-wrap items-center gap-2">
        <span class="badge badge-amber">{data.category || "robot"}</span>
        {data.status && !isPrint && (
          <span class={`badge ${statusBadgeClass(data.status)}`}>{data.status}</span>
        )}
        {isActive && (
          <span class="label-technical inline-flex items-center gap-1.5 text-[10px]" style="color: var(--color-accent);">
            <span class="status-pulse h-1.5 w-1.5 rounded-full" style="background: var(--color-accent);"></span>
            LIVE
          </span>
        )}
      </div>
      <h1
        class="brand-heading text-5xl leading-tight tracking-tight sm:text-6xl md:text-7xl"
        style="color: var(--color-accent);"
      >
        {name}
      </h1>
      {data.concept && (
        <p class="mt-3 text-base sm:text-lg" style="color: var(--color-muted);">
          {data.concept}
        </p>
      )}

      {data.status === "discontinued" && data.discontinued_after && (
        <div
          class="mt-5 flex items-start gap-3 rounded-lg border-l-4 p-4 text-sm"
          style="background: rgba(255, 138, 0, 0.08); border-color: var(--color-accent-strong); color: var(--color-muted);"
        >
          <span class="label-technical shrink-0" style="color: var(--color-accent);">RETIRED</span>
          <span>
            after <strong style="color: var(--color-text);">{data.discontinued_after}</strong>
            {data.discontinued_date && <span> ({data.discontinued_date})</span>}
            {data.successor && resolveRobotLink(data.successor) && (
              <> — succeeded by <a href={resolveRobotLink(data.successor)!.href} class="underline" style="color: var(--color-accent);">{resolveRobotLink(data.successor)!.name}</a></>
            )}
          </span>
        </div>
      )}

      {/* External link bar — CAD/photos/MakerWorld/source */}
      {(data.cad || data.photos || data.makerworld_url || data.source_url) && (
        <div class="mt-6 flex flex-wrap gap-3">
          {data.cad && (
            <a
              href={data.cad}
              target="_blank"
              rel="noopener noreferrer"
              class="label-technical inline-flex items-center gap-2 rounded-full border px-4 py-2 text-xs transition-colors"
              style="border-color: var(--color-border); color: var(--color-text);"
            >
              <span style="color: var(--color-accent);">⚙</span> View CAD in Onshape ↗
            </a>
          )}
          {data.photos && (
            <a
              href={data.photos}
              target="_blank"
              rel="noopener noreferrer"
              class="label-technical inline-flex items-center gap-2 rounded-full border px-4 py-2 text-xs transition-colors"
              style="border-color: var(--color-border); color: var(--color-text);"
            >
              <span style="color: var(--color-accent);">📷</span> Photo album ↗
            </a>
          )}
          {data.makerworld_url && (
            <a
              href={data.makerworld_url}
              target="_blank"
              rel="noopener noreferrer"
              class="label-technical inline-flex items-center gap-2 rounded-full px-4 py-2 text-xs"
              style="background: var(--color-accent); color: var(--color-bg);"
            >
              Download on MakerWorld ↗
            </a>
          )}
          {!data.makerworld_url && data.source_url && (
            <a
              href={data.source_url}
              target="_blank"
              rel="noopener noreferrer"
              class="label-technical inline-flex items-center gap-2 rounded-full border px-4 py-2 text-xs"
              style="border-color: var(--color-border); color: var(--color-text);"
            >
              View on Instagram ↗
            </a>
          )}
        </div>
      )}
    </header>

    {/* Cover image, full-bleed within the container */}
    {data.cover && (
      <div
        class="mb-10 overflow-hidden rounded-xl border"
        style="border-color: var(--color-border); background: var(--color-bg-deep);"
      >
        <img
          src={`/assets/${data.cover}`}
          alt={`${name} cover photo`}
          class="block max-h-[600px] w-full object-cover"
        />
      </div>
    )}

    {/* 8/4 layout: build log + sticky sidebar */}
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-12">
      <article class="lg:col-span-8">
        <h2 class="brand-heading mb-4 text-2xl sm:text-3xl">Build log</h2>
        <div
          class="prose-content rounded-xl border p-5 sm:p-8"
          style="background: var(--color-surface); border-color: var(--color-border);"
        >
          <Content />
        </div>
      </article>

      <aside class="lg:col-span-4">
        <div class="lg:sticky lg:top-24">
          <h2 class="brand-heading mb-4 text-xl">
            {isPrint ? "Print stats" : "Specifications"}
          </h2>
          <div
            class="rounded-xl border p-5"
            style="background: var(--color-surface); border-color: var(--color-border);"
          >
            <dl class="divide-y" style="border-color: var(--color-border);">
              {(isPrint ? printMetrics : specs).map((spec, i) => (
                <div class={`grid grid-cols-[40%_1fr] items-baseline gap-3 py-2.5 ${i > 0 ? "border-t" : ""}`} style="border-color: var(--color-border);">
                  <dt
                    class="label-technical text-[10px]"
                    style="color: var(--color-muted);"
                  >
                    {spec.label}
                  </dt>
                  <dd
                    class="label-technical text-xs"
                    style="color: var(--color-text); overflow-wrap: anywhere;"
                  >
                    {(spec as any).link ? (
                      <a href={(spec as any).link.href} style="color: var(--color-accent);">
                        {(spec as any).link.name}
                      </a>
                    ) : (
                      displayValue(String(spec.value))
                    )}
                  </dd>
                </div>
              ))}
            </dl>
          </div>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>

<style is:global>
  /* Styling for markdown content inside .prose-content. Updated to Stitch
     palette/typography (Bricolage headlines, accent orange links). */
  .prose-content {
    color: var(--color-text);
    overflow-wrap: anywhere;
  }
  /* The print body markdown includes an Obsidian-style ![[cover.png]] image
     so Obsidian shows the photo inline. The same cover is already rendered
     in the page hero, so hide a leading body image to avoid the duplicate. */
  .prose-content > p:first-child:has(> img:only-child) {
    display: none;
  }
  .prose-content > img:first-child {
    display: none;
  }
  .prose-content h2 {
    font-family: var(--font-display);
    color: var(--color-accent);
    font-size: 1.5rem;
    font-weight: 700;
    margin: 2rem 0 0.75rem;
    letter-spacing: -0.01em;
  }
  .prose-content h3 {
    font-family: var(--font-display);
    color: var(--color-text);
    font-size: 1.2rem;
    font-weight: 700;
    margin: 1.5rem 0 0.5rem;
  }
  .prose-content h4 {
    font-family: var(--font-display);
    color: var(--color-text);
    font-size: 1.05rem;
    font-weight: 600;
    margin: 1.25rem 0 0.4rem;
  }
  .prose-content p {
    margin-bottom: 0.85rem;
    line-height: 1.65;
  }
  .prose-content a {
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.15s;
  }
  .prose-content a:hover {
    color: var(--color-accent-strong);
    text-decoration: underline;
  }
  .prose-content strong {
    color: var(--color-text);
    font-weight: 700;
  }
  .prose-content ul,
  .prose-content ol {
    margin: 0.5rem 0 0.85rem 1.25rem;
  }
  .prose-content li {
    margin-bottom: 0.3rem;
    line-height: 1.6;
  }
  .prose-content hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }
  .prose-content img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 1.5rem 0;
    border: 1px solid var(--color-border);
  }
  .prose-content table {
    display: block;
    max-width: 100%;
    overflow-x: auto;
    border-collapse: collapse;
    font-size: 0.85rem;
    margin: 1rem 0;
    font-family: var(--font-mono);
  }
  .prose-content th,
  .prose-content td {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--color-border);
    text-align: left;
  }
  .prose-content th {
    background: var(--color-bg-deep);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.7rem;
  }
  .prose-content pre {
    overflow-x: auto;
    max-width: 100%;
    background: var(--color-bg-deep);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1rem;
    font-size: 0.85rem;
    margin: 1rem 0;
    font-family: var(--font-mono);
  }
  .prose-content code {
    background: var(--color-bg-deep);
    color: var(--color-accent);
    padding: 0.1rem 0.3rem;
    border-radius: 4px;
    font-size: 0.9em;
    font-family: var(--font-mono);
  }
  .prose-content pre code {
    background: transparent;
    padding: 0;
    color: var(--color-text);
  }
  .prose-content blockquote {
    border-left: 3px solid var(--color-accent);
    padding-left: 1rem;
    margin: 1rem 0;
    color: var(--color-muted);
    font-style: italic;
  }

  /* YouTube embed (used inline in markdown via <div class="youtube-embed">) */
  .youtube-embed {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--color-bg-deep);
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    margin: 1.5rem 0;
  }
  .youtube-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  /* Obsidian callouts — re-tuned to Stitch palette (orange accents). */
  .callout {
    border-radius: 10px;
    border-left: 4px solid var(--color-muted);
    background: rgba(54, 51, 67, 0.5);
    padding: 0.85rem 1.1rem 0.6rem;
    margin: 1.5rem 0;
  }
  .callout > .callout-title {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.4rem;
    color: var(--color-muted);
  }
  .callout > *:last-child {
    margin-bottom: 0;
  }
  .callout-warning,
  .callout-failure,
  .callout-danger {
    border-left-color: var(--color-accent);
    background: rgba(255, 138, 0, 0.08);
  }
  .callout-warning > .callout-title,
  .callout-failure > .callout-title,
  .callout-danger > .callout-title {
    color: var(--color-accent);
  }
  .callout-info,
  .callout-note,
  .callout-tip,
  .callout-abstract,
  .callout-question {
    border-left-color: var(--color-secondary);
    background: rgba(203, 195, 216, 0.08);
  }
  .callout-info > .callout-title,
  .callout-note > .callout-title,
  .callout-tip > .callout-title,
  .callout-abstract > .callout-title,
  .callout-question > .callout-title {
    color: var(--color-secondary);
  }
  .callout-success {
    border-left-color: #7dcc9a;
    background: rgba(125, 204, 154, 0.08);
  }
  .callout-success > .callout-title {
    color: #7dcc9a;
  }
  .callout-bug,
  .callout-important {
    border-left-color: var(--color-accent-strong);
    background: rgba(255, 138, 0, 0.12);
  }
  .callout-bug > .callout-title,
  .callout-important > .callout-title {
    color: var(--color-accent-strong);
  }
</style>
