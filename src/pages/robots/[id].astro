---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { resolveWikiLink, resolveRobotLink, displayValue } from "../../lib/utils";

export async function getStaticPaths() {
  const robots = await getCollection("robots");
  return robots.map((robot) => ({
    params: { id: robot.id },
    props: { robot },
  }));
}

const { robot } = Astro.props;
const { Content } = await render(robot);
const data = robot.data;

const name = data.robot_name || robot.id;

const weightDisplay = data.weight
  ? `${data.weight}g`
  : data.target_weight
    ? `${data.target_weight}g (target)`
    : data.weight_note
      ? data.weight_note
      : undefined;

const specs = [
  { label: "Status", value: data.status },
  { label: "Category", value: data.category },
  { label: "Weight", value: weightDisplay },
  { label: "Predecessor", value: data.predecessor, link: resolveRobotLink(data.predecessor) },
  { label: "Successor", value: data.successor, link: resolveRobotLink(data.successor) },
  { label: "Weapon Type", value: data.weapon_type },
  { label: "Weapon Mass", value: data.weapon_mass },
  { label: "Weapon Hardware", value: data.weapon_hardware },
  { label: "Weapon Motor", value: data.weapon_motor },
  { label: "Weapon Drive", value: data.weapon_drive },
  { label: "Drum OD", value: data.weapon_drum_od },
  { label: "Drum Length", value: data.weapon_drum_length },
  { label: "Drum Bore", value: data.weapon_drum_bore },
  { label: "Drum Shaft", value: data.weapon_drum_shaft },
  { label: "Drum Bearings", value: data.weapon_drum_bearings },
  { label: "Tooth Fastener", value: data.weapon_tooth_fastener },
  { label: "Battery", value: data.battery_voltage, link: resolveWikiLink(data.battery_voltage) },
  { label: "Gearing", value: data.gearing },
  { label: "Drive Motors", value: data.drive_motors, link: resolveWikiLink(data.drive_motors) },
  { label: "Drive Layout", value: data.drive_layout },
  { label: "Wheel Pulley", value: data.wheel_pulley_diameter },
  { label: "Wheels", value: data.wheels },
  { label: "Armor", value: data.armor_material },
  { label: "Wedge", value: data.wedge_specs },
  { label: "Receiver", value: data.receiver, link: resolveWikiLink(data.receiver) },
].filter((s) => s.value);

const statusBadgeClass = (status: string | undefined) => {
  if (!status) return "";
  if (status === "discontinued" || status === "retired") return "badge-orange-outline";
  return "badge-sky";
};
---

<BaseLayout
  title={`${name} — Nerdy Layers 3D`}
  description={data.concept || `${name} — a Nerdy Layers 3D project.`}
  image={data.cover}
>
  <div>
    <a href="/" class="mb-6 inline-block text-sm" style="color: var(--color-muted);">
      ← All Projects
    </a>

    <header class="mb-8">
      <div class="mb-3 flex flex-wrap items-center gap-2">
        <span class="badge badge-amber">{data.category || "robot"}</span>
        {data.status && (
          <span class={`badge ${statusBadgeClass(data.status)}`}>{data.status}</span>
        )}
      </div>
      <h1 class="brand-heading text-4xl sm:text-5xl md:text-6xl">{name}</h1>
      {data.concept && (
        <p class="mt-2 text-lg italic" style="color: var(--color-muted);">
          {data.concept}
        </p>
      )}
      {data.status === "discontinued" && data.discontinued_after && (
        <p
          class="mt-3 rounded border-l-4 px-3 py-2 text-sm"
          style="background: rgba(232,92,44,0.08); border-color: var(--color-accent-shadow); color: var(--color-muted);"
        >
          Retired after <strong style="color: var(--color-accent);">{data.discontinued_after}</strong>
          {data.discontinued_date && <span> ({data.discontinued_date})</span>}
          {data.successor && resolveRobotLink(data.successor) && (
            <> — succeeded by <a href={resolveRobotLink(data.successor)!.href} class="underline">{resolveRobotLink(data.successor)!.name}</a></>
          )}
        </p>
      )}
      {(data.cad || data.photos) && (
        <p class="mt-3 flex flex-wrap gap-5 text-sm">
          {data.cad && (
            <a href={data.cad} target="_blank" rel="noopener noreferrer" style="color: var(--color-link);">
              View CAD in Onshape →
            </a>
          )}
          {data.photos && (
            <a href={data.photos} target="_blank" rel="noopener noreferrer" style="color: var(--color-link);">
              Photo album →
            </a>
          )}
        </p>
      )}
    </header>

    <section
      class="mb-8 rounded-lg border p-5 sm:p-6"
      style="background: var(--color-surface); border-color: var(--color-border);"
    >
      <h2 class="brand-heading-sky mb-4 text-xl">Specifications</h2>
      <dl class="divide-y" style="--tw-divide-opacity:1; border-color: var(--color-border);">
        {specs.map((spec, i) => (
          <div class={`grid grid-cols-[35%_1fr] gap-3 py-2 ${i > 0 ? 'border-t' : ''}`} style="border-color: var(--color-border);">
            <dt class="text-sm" style="color: var(--color-muted);">{spec.label}</dt>
            <dd class="text-sm font-medium sm:text-base" style="overflow-wrap: anywhere;">
              {spec.link ? (
                <a href={spec.link.href} style="color: var(--color-link);">{spec.link.name}</a>
              ) : (
                displayValue(spec.value!)
              )}
            </dd>
          </div>
        ))}
      </dl>
    </section>

    <section
      class="rounded-lg border p-5 sm:p-8"
      style="background: var(--color-surface); border-color: var(--color-border);"
    >
      <div class="prose-content">
        <Content />
      </div>
    </section>
  </div>
</BaseLayout>

<style is:global>
  /* Styling for markdown content inside .prose-content. Tailwind v4's @apply
     inside scoped Astro <style> blocks can be finicky, so we use vanilla CSS
     keyed on a class instead. */
  .prose-content {
    color: var(--color-text);
    overflow-wrap: anywhere;
  }
  .prose-content h2 {
    font-family: var(--font-display);
    color: var(--color-secondary);
    font-size: 1.5rem;
    font-weight: 600;
    margin: 2rem 0 0.75rem;
  }
  .prose-content h3 {
    font-family: var(--font-display);
    color: var(--color-text);
    font-size: 1.2rem;
    font-weight: 600;
    margin: 1.5rem 0 0.5rem;
  }
  .prose-content h4 {
    font-family: var(--font-display);
    color: var(--color-text);
    font-size: 1.05rem;
    font-weight: 600;
    margin: 1.25rem 0 0.4rem;
  }
  .prose-content p {
    margin-bottom: 0.75rem;
  }
  .prose-content a {
    color: var(--color-link);
    text-decoration: none;
    transition: color 0.15s;
  }
  .prose-content a:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }
  .prose-content strong {
    color: var(--color-accent);
  }
  .prose-content ul,
  .prose-content ol {
    margin: 0.5rem 0 0.75rem 1.25rem;
  }
  .prose-content li {
    margin-bottom: 0.25rem;
  }
  .prose-content hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }
  .prose-content img {
    max-width: 100%;
    height: auto;
    border-radius: 6px;
    margin: 1rem 0;
  }
  .prose-content table {
    display: block;
    max-width: 100%;
    overflow-x: auto;
    border-collapse: collapse;
    font-size: 0.85rem;
    margin: 1rem 0;
  }
  .prose-content th,
  .prose-content td {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--color-border);
    text-align: left;
  }
  .prose-content th {
    background: var(--color-bg-deep);
    color: var(--color-secondary);
  }
  .prose-content pre {
    overflow-x: auto;
    max-width: 100%;
    background: var(--color-bg-deep);
    border-radius: 6px;
    padding: 1rem;
    font-size: 0.85rem;
    margin: 1rem 0;
  }
  .prose-content code {
    background: var(--color-bg-deep);
    color: var(--color-secondary);
    padding: 0.1rem 0.3rem;
    border-radius: 3px;
    font-size: 0.9em;
  }
  .prose-content pre code {
    background: transparent;
    padding: 0;
  }
  .prose-content blockquote {
    border-left: 3px solid var(--color-secondary);
    padding-left: 1rem;
    margin: 1rem 0;
    color: var(--color-muted);
    font-style: italic;
  }

  /* YouTube embed (used inline in markdown via <div class="youtube-embed">) */
  .youtube-embed {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--color-bg-deep);
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    margin: 1.5rem 0;
  }
  .youtube-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  /* Obsidian callouts (rendered by remark-callouts.mjs) */
  .callout {
    border-radius: 8px;
    border-left: 4px solid var(--color-muted);
    background: rgba(58, 50, 86, 0.4);
    padding: 0.85rem 1rem 0.5rem;
    margin: 1.25rem 0;
  }
  .callout > .callout-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.4rem;
    color: var(--color-muted);
  }
  .callout > *:last-child {
    margin-bottom: 0;
  }
  .callout-warning,
  .callout-failure,
  .callout-danger {
    border-left-color: var(--color-accent);
    background: rgba(244, 164, 74, 0.08);
  }
  .callout-warning > .callout-title,
  .callout-failure > .callout-title,
  .callout-danger > .callout-title {
    color: var(--color-accent);
  }
  .callout-info,
  .callout-note,
  .callout-tip,
  .callout-abstract,
  .callout-question {
    border-left-color: var(--color-secondary);
    background: rgba(125, 204, 232, 0.08);
  }
  .callout-info > .callout-title,
  .callout-note > .callout-title,
  .callout-tip > .callout-title,
  .callout-abstract > .callout-title,
  .callout-question > .callout-title {
    color: var(--color-secondary);
  }
  .callout-success {
    border-left-color: #7dcc9a;
    background: rgba(125, 204, 154, 0.08);
  }
  .callout-success > .callout-title {
    color: #7dcc9a;
  }
  .callout-bug,
  .callout-important {
    border-left-color: var(--color-accent-shadow);
    background: rgba(232, 92, 44, 0.1);
  }
  .callout-bug > .callout-title,
  .callout-important > .callout-title {
    color: var(--color-accent-shadow);
  }
</style>
