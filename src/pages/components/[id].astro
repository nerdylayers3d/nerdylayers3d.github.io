---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const components = await getCollection("components");
  return components.map((component) => ({
    params: { id: component.id },
    props: { component },
  }));
}

const { component } = Astro.props;
const { Content, headings } = await render(component);
const data = component.data;

const firstH1 = headings?.find((h) => h.depth === 1)?.text;
const humanizedId = component.id
  .replace(/-/g, " ")
  .replace(/\b\w/g, (c) => c.toUpperCase());
const title = data.title || firstH1 || humanizedId;

const meta = [
  data.price && { label: "Price", value: `€${data.price}`, accent: true },
  data.source && {
    label: "Source",
    value: new URL(data.source).hostname.replace("www.", "") + " ↗",
    href: data.source,
  },
  data.created && { label: "Saved", value: data.created },
].filter(Boolean);
---

<BaseLayout
  title={`${title} — Nerdy Layers 3D`}
  description={data.description}
  image={data.main_image}
>
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-8 sm:py-12">
    <a
      href="/"
      class="label-technical mb-6 inline-flex items-center gap-1 text-xs"
      style="color: var(--color-muted);"
    >
      ← Back to projects
    </a>

    <header class="mb-8">
      {data.tags && data.tags.length > 0 && (
        <div class="mb-3 flex flex-wrap gap-2">
          {data.tags.map((tag: string) => (
            <span class="badge badge-amber">{tag}</span>
          ))}
        </div>
      )}
      <h1
        class="brand-heading text-4xl leading-tight tracking-tight sm:text-5xl md:text-6xl"
        style="color: var(--color-accent);"
      >
        {title}
      </h1>
      {data.description && (
        <p class="mt-3 text-base sm:text-lg" style="color: var(--color-muted);">
          {data.description}
        </p>
      )}
    </header>

    {meta.length > 0 && (
      <div
        class="mb-8 grid grid-cols-2 gap-4 rounded-xl border p-5 sm:grid-cols-3 sm:gap-6"
        style="background: var(--color-surface); border-color: var(--color-border);"
      >
        {meta.map((m: any) => (
          <div class="flex flex-col gap-1">
            <span class="label-technical text-[10px]" style="color: var(--color-muted);">
              {m.label}
            </span>
            {m.href ? (
              <a
                href={m.href}
                target="_blank"
                rel="noopener noreferrer"
                class="text-base font-semibold"
                style="color: var(--color-accent);"
              >
                {m.value}
              </a>
            ) : (
              <span
                class={m.accent ? "text-2xl font-bold" : "text-base font-semibold"}
                style={m.accent ? "color: var(--color-accent);" : "color: var(--color-text);"}
              >
                {m.value}
              </span>
            )}
          </div>
        ))}
      </div>
    )}

    {data.main_image && (
      <div
        class="mb-8 overflow-hidden rounded-xl border"
        style="border-color: var(--color-border); background: var(--color-bg-deep);"
      >
        <img
          src={data.main_image}
          alt={title}
          loading="lazy"
          class="block max-h-[500px] w-full object-contain"
        />
      </div>
    )}

    <section
      class="rounded-xl border p-5 sm:p-8"
      style="background: var(--color-surface); border-color: var(--color-border);"
    >
      <div class="prose-content">
        <Content />
      </div>
    </section>
  </div>
</BaseLayout>

<style is:global>
  /* Hide a duplicate H1 at the top of the body when the page already shows
     it in the header (Clippings often start with an H1 of the same title). */
  .prose-content > h1:first-child {
    display: none;
  }
</style>
