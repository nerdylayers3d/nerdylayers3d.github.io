---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const components = await getCollection("components");
  return components.map((component) => ({
    params: { id: component.id },
    props: { component },
  }));
}

const { component } = Astro.props;
const { Content, headings } = await render(component);
const data = component.data;

const firstH1 = headings?.find((h) => h.depth === 1)?.text;
const humanizedId = component.id
  .replace(/-/g, " ")
  .replace(/\b\w/g, (c) => c.toUpperCase());
const title = data.title || firstH1 || humanizedId;

const hasMeta = data.price || data.source || data.created;
---

<BaseLayout
  title={`${title} — Nerdy Layers 3D`}
  description={data.description}
  image={data.main_image}
>
  <div>
    <a href="/" class="mb-6 inline-block text-sm" style="color: var(--color-muted);">
      ← All Projects
    </a>

    <header class="mb-6">
      {data.tags && data.tags.length > 0 && (
        <div class="mb-2 flex flex-wrap gap-2">
          {data.tags.map((tag: string) => (
            <span class="rounded px-2 py-0.5 text-xs uppercase tracking-wider" style="background: var(--color-border); color: var(--color-muted);">
              {tag}
            </span>
          ))}
        </div>
      )}
      <h1 class="brand-heading text-3xl sm:text-4xl md:text-5xl">{title}</h1>
      {data.description && (
        <p class="mt-2 text-sm" style="color: var(--color-muted);">{data.description}</p>
      )}
    </header>

    {hasMeta && (
      <div class="mb-6 flex flex-wrap gap-6 rounded-lg border p-4 sm:p-5" style="background: var(--color-surface); border-color: var(--color-border);">
        {data.price && (
          <div class="flex flex-col gap-0.5">
            <span class="text-xs uppercase tracking-wider" style="color: var(--color-muted);">Price</span>
            <span class="text-xl font-bold" style="color: var(--color-accent);">€{data.price}</span>
          </div>
        )}
        {data.source && (
          <div class="flex flex-col gap-0.5">
            <span class="text-xs uppercase tracking-wider" style="color: var(--color-muted);">Source</span>
            <a href={data.source} target="_blank" rel="noopener noreferrer" class="font-medium" style="color: var(--color-link);">
              {new URL(data.source).hostname.replace("www.", "")} ↗
            </a>
          </div>
        )}
        {data.created && (
          <div class="flex flex-col gap-0.5">
            <span class="text-xs uppercase tracking-wider" style="color: var(--color-muted);">Saved</span>
            <span class="font-semibold">{data.created}</span>
          </div>
        )}
      </div>
    )}

    {data.main_image && (
      <div class="mb-6 overflow-hidden rounded-lg border" style="border-color: var(--color-border); background: var(--color-surface);">
        <img src={data.main_image} alt={title} loading="lazy" class="block max-h-[400px] w-full object-contain" />
      </div>
    )}

    <section class="rounded-lg border p-5 sm:p-8" style="background: var(--color-surface); border-color: var(--color-border);">
      <div class="prose-content">
        <Content />
      </div>
    </section>
  </div>
</BaseLayout>

<style is:global>
  /* Hide a duplicate H1 at the top of the body when the page already shows it in the header */
  .prose-content > h1:first-child {
    display: none;
  }
</style>
