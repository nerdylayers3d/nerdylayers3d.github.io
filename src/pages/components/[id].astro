---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const components = await getCollection("components");
  return components.map((component) => ({
    params: { id: component.id },
    props: { component },
  }));
}

const { component } = Astro.props;
const { Content, headings } = await render(component);
const data = component.data;

const firstH1 = headings?.find((h) => h.depth === 1)?.text;
const humanizedId = component.id
  .replace(/-/g, " ")
  .replace(/\b\w/g, (c) => c.toUpperCase());
const title = data.title || firstH1 || humanizedId;

const meta = [
  data.price && { label: "Price", value: `€${data.price}`, accent: true },
  data.source && {
    label: "Source",
    value: new URL(data.source).hostname.replace("www.", "") + " ↗",
    href: data.source,
  },
  data.created && { label: "Saved", value: data.created },
].filter(Boolean);
---

<BaseLayout
  title={`${title} — Nerdy Layers 3D`}
  description={data.description}
  image={data.main_image}
>
  <div class="mx-auto max-w-[1280px] px-4 py-8 sm:px-8 sm:py-12">
    <a
      href="/"
      class="font-label-technical text-label-technical mb-6 inline-flex items-center gap-1 text-on-surface-variant transition-colors hover:text-primary"
    >
      <span class="material-symbols-outlined text-base">arrow_back</span>
      Back to projects
    </a>

    <header class="mb-8">
      {data.tags && data.tags.length > 0 && (
        <div class="mb-3 flex flex-wrap gap-2">
          {data.tags.map((tag: string) => (
            <span class="rounded bg-surface-container-high px-3 py-1 font-label-technical text-xs uppercase text-secondary">
              {tag}
            </span>
          ))}
        </div>
      )}
      <h1 class="font-display-lg text-display-lg leading-tight tracking-tight text-white">
        {title}
      </h1>
      {data.description && (
        <p class="font-body-lg text-body-lg mt-3 text-on-surface-variant">
          {data.description}
        </p>
      )}
    </header>

    {meta.length > 0 && (
      <div class="mb-8 grid grid-cols-2 gap-4 rounded-xl border border-outline-variant bg-surface-container p-5 sm:grid-cols-3 sm:gap-6">
        {meta.map((m: any) => (
          <div class="flex flex-col gap-1">
            <span class="font-label-technical text-[10px] text-on-surface-variant">
              {m.label}
            </span>
            {m.href ? (
              <a
                href={m.href}
                target="_blank"
                rel="noopener noreferrer"
                class="text-base font-semibold text-primary hover:underline"
              >
                {m.value}
              </a>
            ) : (
              <span class={m.accent ? "text-2xl font-bold text-primary" : "text-base font-semibold text-white"}>
                {m.value}
              </span>
            )}
          </div>
        ))}
      </div>
    )}

    {data.main_image && (
      <div class="mb-8 overflow-hidden rounded-xl border border-outline-variant bg-surface-container-lowest">
        <img
          src={data.main_image}
          alt={title}
          loading="lazy"
          class="block max-h-[500px] w-full object-contain"
        />
      </div>
    )}

    <section class="rounded-xl border border-outline-variant bg-surface-container p-5 sm:p-8">
      <div class="prose-content">
        <Content />
      </div>
    </section>
  </div>
</BaseLayout>

<style is:global>
  /* Hide a duplicate H1 at the top of the body when the page already shows
     it in the header (Clippings often start with an H1 of the same title). */
  .prose-content > h1:first-child {
    display: none;
  }
</style>
