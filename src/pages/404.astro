---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found — Nerdy Layers 3D">
  <div class="py-16 text-center sm:py-24">
    <h1 class="brand-heading text-7xl sm:text-8xl">404</h1>
    <p class="mt-2 text-lg sm:text-xl" style="color: var(--color-text);">
      This page doesn't exist (yet).
    </p>
    <p class="mt-2" style="color: var(--color-muted);">
      The link you followed is either broken or the page has been moved.
    </p>
    <a
      href="/"
      class="mt-6 inline-block rounded-full px-6 py-3 font-semibold transition-transform hover:-translate-y-0.5 hover:no-underline"
      style="background: var(--color-accent); color: var(--color-bg); box-shadow: 0 3px 0 var(--color-accent-shadow); font-family: var(--font-display);"
    >
      ← Back to projects
    </a>
  </div>
</BaseLayout>
