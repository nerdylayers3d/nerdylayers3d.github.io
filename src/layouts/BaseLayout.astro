---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/nerdy-layers-logo.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fredoka:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" />
    <title>{title}</title>
  </head>
  <body>
    <nav>
      <a href="/" class="nav-brand">
        <img src="/nerdy-layers-logo.png" alt="Nerdy Layers 3D" class="nav-logo" />
        <span class="nav-text">Nerdy Layers</span>
      </a>
    </nav>
    <main>
      <slot />
    </main>
    <footer>
      <div class="footer-social">
        <a href="https://www.facebook.com/nerdylayers3d" target="_blank" rel="noopener noreferrer" aria-label="Nerdy Layers 3D on Facebook">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
        </a>
        <a href="https://www.instagram.com/nerdylayers3d" target="_blank" rel="noopener noreferrer" aria-label="Nerdy Layers 3D on Instagram">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 1.366.062 2.633.336 3.608 1.311.975.975 1.249 2.242 1.311 3.608.058 1.266.069 1.646.069 4.85s-.011 3.584-.069 4.85c-.062 1.366-.336 2.633-1.311 3.608-.975.975-2.242 1.249-3.608 1.311-1.266.058-1.646.069-4.85.069s-3.584-.011-4.85-.069c-1.366-.062-2.633-.336-3.608-1.311-.975-.975-1.249-2.242-1.311-3.608C2.175 15.747 2.163 15.368 2.163 12s.012-3.584.07-4.85c.062-1.366.336-2.633 1.311-3.608.975-.975 2.242-1.249 3.608-1.311C8.416 2.175 8.796 2.163 12 2.163zm0 1.802c-3.142 0-3.516.012-4.756.068-1.014.047-1.565.215-1.93.358-.485.188-.832.413-1.196.777-.364.364-.589.711-.777 1.196-.143.366-.311.916-.358 1.93-.056 1.24-.068 1.614-.068 4.756 0 3.142.012 3.516.068 4.756.047 1.014.215 1.565.358 1.93.188.485.413.832.777 1.196.364.364.711.589 1.196.777.366.143.916.311 1.93.358 1.24.056 1.614.068 4.756.068 3.142 0 3.516-.012 4.756-.068 1.014-.047 1.565-.215 1.93-.358.485-.188.832-.413 1.196-.777.364-.364.589-.711.777-1.196.143-.366.311-.916.358-1.93.056-1.24.068-1.614.068-4.756 0-3.142-.012-3.516-.068-4.756-.047-1.014-.215-1.565-.358-1.93-.188-.485-.413-.832-.777-1.196-.364-.364-.711-.589-1.196-.777-.366-.143-.916-.311-1.93-.358-1.24-.056-1.614-.068-4.756-.068zM12 6.865a5.135 5.135 0 100 10.27 5.135 5.135 0 000-10.27zm0 8.468a3.333 3.333 0 110-6.666 3.333 3.333 0 010 6.666zm6.538-8.671a1.2 1.2 0 11-2.4 0 1.2 1.2 0 012.4 0z"/></svg>
        </a>
      </div>
      <p class="footer-brand">Nerdy Layers 3D</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    /* Nerdy Layers 3D palette */
    --bg: #1f1b2e;           /* deep navy-purple from logo background */
    --bg-deep: #161220;      /* even darker for image frames */
    --surface: #2a2540;      /* card / nav surface */
    --surface-hover: #352e50;
    --border: #3d3656;
    --text: #f4ede0;         /* warm off-white (matches logo highlights) */
    --text-muted: #a39db8;
    --accent: #f4a44a;       /* amber/orange — primary logo top color */
    --accent-shadow: #e85c2c; /* orange shadow tone */
    --secondary: #7dcce8;    /* sky-blue from logo */
    --secondary-shadow: #4ea3c5;
    --link: #7dcce8;
    --link-hover: #f4a44a;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
  }

  body {
    background:
      radial-gradient(ellipse at top, rgba(244, 164, 74, 0.06), transparent 60%),
      radial-gradient(ellipse at bottom, rgba(125, 204, 232, 0.04), transparent 60%),
      var(--bg);
    min-height: 100vh;
    overflow-x: hidden;
  }

  a {
    color: var(--link);
    text-decoration: none;
    transition: color 0.15s;
  }

  a:hover {
    color: var(--link-hover);
    text-decoration: underline;
  }

  nav {
    padding: 0.75rem 1.25rem;
    border-bottom: 2px solid var(--accent);
    background: var(--surface);
    box-shadow: 0 4px 18px rgba(0, 0, 0, 0.3);
  }

  .nav-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: "Fredoka", "Inter", sans-serif;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.02em;
    text-shadow: 1px 2px 0 var(--accent-shadow);
  }

  .nav-brand:hover {
    text-decoration: none;
    color: var(--secondary);
    text-shadow: 1px 2px 0 var(--secondary-shadow);
  }

  .nav-logo {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    border: 0;
    object-fit: cover;
  }

  .nav-text {
    line-height: 1;
  }

  main {
    max-width: 1320px;
    margin: 1.25rem auto;
    padding: 0 1rem;
  }

  footer {
    max-width: 1320px;
    margin: 3rem auto 1.5rem;
    padding: 1.25rem 1rem;
    border-top: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.85rem;
    text-align: center;
  }

  .footer-social {
    display: flex;
    justify-content: center;
    gap: 1.25rem;
    margin-bottom: 0.6rem;
  }

  .footer-social a {
    color: var(--text-muted);
    transition: color 0.15s, transform 0.15s;
    display: inline-flex;
    align-items: center;
  }

  .footer-social a:hover {
    color: var(--accent);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .footer-brand {
    font-family: "Fredoka", "Inter", sans-serif;
    color: var(--accent);
    font-weight: 600;
    letter-spacing: 0.02em;
    margin: 0;
  }

  h1 {
    font-family: "Fredoka", "Inter", sans-serif;
    font-size: clamp(1.75rem, 6vw, 2.4rem);
    font-weight: 700;
    color: var(--accent);
    text-shadow: 2px 3px 0 var(--accent-shadow);
    margin-bottom: 0.5rem;
    letter-spacing: 0.01em;
    overflow-wrap: anywhere;
  }

  h2 {
    font-family: "Fredoka", "Inter", sans-serif;
    font-size: clamp(1.25rem, 4.5vw, 1.6rem);
    font-weight: 600;
    margin: 2rem 0 0.75rem;
    color: var(--secondary);
  }

  h3 {
    font-family: "Fredoka", "Inter", sans-serif;
    font-size: clamp(1.05rem, 3.5vw, 1.25rem);
    font-weight: 600;
    margin: 1.5rem 0 0.5rem;
    color: var(--text);
  }

  @media (min-width: 640px) {
    nav { padding: 1rem 2rem; }
    .nav-brand { font-size: 1.4rem; gap: 0.75rem; }
    .nav-logo { width: 44px; height: 44px; }
    main { margin: 2rem auto; padding: 0 2rem; }
    footer { margin: 4rem auto 2rem; padding: 1.25rem 2rem; }
  }

  p {
    margin-bottom: 0.75rem;
  }

  ul, ol {
    margin-left: 1.25rem;
    margin-bottom: 0.75rem;
  }

  li {
    margin-bottom: 0.25rem;
  }

  strong {
    color: var(--accent);
  }

  img {
    max-width: 100%;
    height: auto;
    border-radius: 4px;
  }

  table {
    border-collapse: collapse;
  }

  /* Obsidian-style callouts */
  .callout {
    border-radius: 8px;
    border-left: 4px solid var(--text-muted);
    background: rgba(58, 50, 86, 0.4);
    padding: 0.85rem 1rem 0.5rem;
    margin: 1.25rem 0;
  }

  .callout > .callout-title {
    font-family: "Fredoka", "Inter", sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.4rem;
    color: var(--text-muted);
  }

  .callout > *:last-child {
    margin-bottom: 0;
  }

  .callout-warning,
  .callout-failure,
  .callout-danger {
    border-left-color: #f4a44a;
    background: rgba(244, 164, 74, 0.08);
  }
  .callout-warning > .callout-title,
  .callout-failure > .callout-title,
  .callout-danger > .callout-title {
    color: #f4a44a;
  }

  .callout-info,
  .callout-note,
  .callout-tip,
  .callout-abstract,
  .callout-question {
    border-left-color: var(--secondary);
    background: rgba(125, 204, 232, 0.08);
  }
  .callout-info > .callout-title,
  .callout-note > .callout-title,
  .callout-tip > .callout-title,
  .callout-abstract > .callout-title,
  .callout-question > .callout-title {
    color: var(--secondary);
  }

  .callout-success {
    border-left-color: #7dcc9a;
    background: rgba(125, 204, 154, 0.08);
  }
  .callout-success > .callout-title {
    color: #7dcc9a;
  }

  .callout-bug,
  .callout-important {
    border-left-color: #e85c2c;
    background: rgba(232, 92, 44, 0.1);
  }
  .callout-bug > .callout-title,
  .callout-important > .callout-title {
    color: #e85c2c;
  }
</style>
