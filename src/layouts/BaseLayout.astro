---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  image?: string;
}
const { title, description, image } = Astro.props;

const SITE_URL = "https://nerdylayers3d.com";
const SITE_NAME = "Nerdy Layers 3D";
const DEFAULT_DESCRIPTION =
  "I build combat robots and 3D-printed things. Sometimes they work.";
const DEFAULT_OG_IMAGE = `${SITE_URL}/nerdy-layers-logo.png`;

const pageDescription = description || DEFAULT_DESCRIPTION;
const resolvedImage = image
  ? image.startsWith("http")
    ? image
    : `${SITE_URL}/assets/${image}`
  : DEFAULT_OG_IMAGE;
const canonicalUrl = new URL(Astro.url.pathname, SITE_URL).toString();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/nerdy-layers-logo.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonicalUrl} />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={resolvedImage} />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={resolvedImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@500;600&display=swap"
    />
    {/* Material Symbols (icon font used by the Stitch components). */}
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap"
    />
  </head>

  <body class="flex min-h-screen flex-col overflow-x-hidden bg-surface text-on-surface font-body-md">
    {/* Top nav — lifted from Stitch reference: sticky transparent-blurred bar
        with logo + section links. Material Symbols arrow icons on hover. */}
    <nav class="sticky top-0 z-50 w-full border-b border-outline-variant bg-surface/85 backdrop-blur-md">
      <div class="mx-auto flex w-full max-w-[1280px] items-center justify-between px-4 py-3 sm:px-8 sm:py-4">
        <a href="/" class="inline-flex items-center gap-3 no-underline">
          <img
            src="/nerdy-layers-logo.png"
            alt="Nerdy Layers 3D"
            class="h-9 w-9 object-contain sm:h-10 sm:w-10"
          />
          <span class="font-headline-md text-headline-md font-bold text-primary">
            Nerdy Layers 3D
          </span>
        </a>
        <div class="hidden items-center gap-8 md:flex">
          <a
            href="/#projects"
            class="font-body-md text-body-md text-on-surface transition-colors duration-200 hover:text-primary"
          >Projects</a>
          <a
            href="https://makerworld.com/en/@nerdylayers3d"
            target="_blank"
            rel="noopener noreferrer"
            class="font-body-md text-body-md text-on-surface-variant transition-colors duration-200 hover:text-primary"
          >MakerWorld</a>
          <a
            href="https://www.instagram.com/nerdylayers3d"
            target="_blank"
            rel="noopener noreferrer"
            class="font-body-md text-body-md text-on-surface-variant transition-colors duration-200 hover:text-primary"
          >Instagram</a>
        </div>
        <button class="text-primary md:hidden" aria-label="Open menu">
          <span class="material-symbols-outlined">menu</span>
        </button>
      </div>
    </nav>

    <!-- Main grows to fill remaining vertical space. No padding here; each
         page section sets its own container/padding so the hero can run
         full-bleed. -->
    <main class="w-full flex-1">
      <slot />
    </main>

    {/* Footer — Stitch reference structure: brand block on the left, link row
        on the right, separated by a thin outline-variant border. */}
    <footer class="border-t border-outline-variant bg-surface-container-lowest">
      <div class="mx-auto flex w-full max-w-[1280px] flex-col items-center justify-between gap-6 px-4 py-10 sm:px-8 md:flex-row md:py-12">
        <div class="flex flex-col items-center gap-3 md:items-start">
          <div class="flex items-center gap-3">
            <img
              src="/nerdy-layers-logo.png"
              alt="Nerdy Layers Logo"
              class="h-8 w-8 object-contain opacity-90"
            />
            <span class="font-headline-md text-headline-md text-primary">
              Nerdy Layers 3D
            </span>
          </div>
          <p class="font-label-technical text-label-technical text-on-surface-variant">
            © 2026 Nerdy Layers 3D. Precision engineered.
          </p>
        </div>
        <div class="flex flex-wrap justify-center gap-6 md:gap-8">
          <a
            href="https://makerworld.com/en/@nerdylayers3d"
            target="_blank"
            rel="noopener noreferrer"
            class="font-label-technical text-label-technical text-on-surface-variant opacity-80 transition-colors hover:text-primary hover:opacity-100"
          >MakerWorld</a>
          <a
            href="https://www.printables.com/@nerdylayers3d"
            target="_blank"
            rel="noopener noreferrer"
            class="font-label-technical text-label-technical text-on-surface-variant opacity-80 transition-colors hover:text-primary hover:opacity-100"
          >Printables</a>
          <a
            href="https://www.instagram.com/nerdylayers3d"
            target="_blank"
            rel="noopener noreferrer"
            class="font-label-technical text-label-technical text-on-surface-variant opacity-80 transition-colors hover:text-primary hover:opacity-100"
          >Instagram</a>
          <a
            href="https://www.facebook.com/nerdylayers3d"
            target="_blank"
            rel="noopener noreferrer"
            class="font-label-technical text-label-technical text-on-surface-variant opacity-80 transition-colors hover:text-primary hover:opacity-100"
          >Facebook</a>
        </div>
      </div>
    </footer>
  </body>
</html>
