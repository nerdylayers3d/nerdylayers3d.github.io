---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  image?: string;
}
const { title, description, image } = Astro.props;

const SITE_URL = "https://nerdylayers3d.com";
const SITE_NAME = "Nerdy Layers 3D";
const DEFAULT_DESCRIPTION =
  "Combat robotics builds, 3D-printed mechanisms, and electronics tinkering by Nerdy Layers 3D.";
const DEFAULT_OG_IMAGE = `${SITE_URL}/nerdy-layers-logo.png`;

const pageDescription = description || DEFAULT_DESCRIPTION;
const resolvedImage = image
  ? image.startsWith("http")
    ? image
    : `${SITE_URL}/assets/${image}`
  : DEFAULT_OG_IMAGE;
const canonicalUrl = new URL(Astro.url.pathname, SITE_URL).toString();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/nerdy-layers-logo.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonicalUrl} />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={resolvedImage} />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={resolvedImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fredoka:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap"
    />
  </head>

  <body class="flex min-h-screen flex-col overflow-x-hidden">
    <!-- Nav: full width, content-aligned start -->
    <nav
      class="flex w-full items-center border-b-2 px-5 py-3 shadow-[0_4px_18px_rgba(0,0,0,0.3)] sm:px-8 sm:py-4"
      style="border-color: var(--color-accent); background: var(--color-surface);"
    >
      <a
        href="/"
        class="brand-heading inline-flex items-center gap-2.5 text-xl no-underline hover:[color:var(--color-secondary)] sm:gap-3 sm:text-2xl"
      >
        <img
          src="/nerdy-layers-logo.png"
          alt="Nerdy Layers 3D"
          class="h-9 w-9 rounded-lg object-cover sm:h-11 sm:w-11"
        />
        <span class="leading-none">Nerdy Layers</span>
      </a>
    </nav>

    <!-- Main grows to fill remaining vertical space so footer hugs the bottom -->
    <main class="w-full flex-1 px-5 py-5 sm:px-8 sm:py-8">
      <slot />
    </main>

    <!-- Footer: full width, content centered horizontally inside it -->
    <footer
      class="w-full px-5 py-6 text-center text-sm sm:px-8"
      style="color: var(--color-muted); border-top: 1px solid var(--color-border);"
    >
      <div class="mb-2 flex justify-center gap-5">
        <a
          href="https://www.facebook.com/nerdylayers3d"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Nerdy Layers 3D on Facebook"
          class="inline-flex items-center transition-transform hover:-translate-y-0.5 hover:[color:var(--color-accent)]"
          style="color: var(--color-muted);"
        >
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
            ><path
              d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"
            ></path></svg
          >
        </a>
        <a
          href="https://www.instagram.com/nerdylayers3d"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Nerdy Layers 3D on Instagram"
          class="inline-flex items-center transition-transform hover:-translate-y-0.5 hover:[color:var(--color-accent)]"
          style="color: var(--color-muted);"
        >
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
            ><path
              d="M12 2.163c3.204 0 3.584.012 4.85.07 1.366.062 2.633.336 3.608 1.311.975.975 1.249 2.242 1.311 3.608.058 1.266.069 1.646.069 4.85s-.011 3.584-.069 4.85c-.062 1.366-.336 2.633-1.311 3.608-.975.975-2.242 1.249-3.608 1.311-1.266.058-1.646.069-4.85.069s-3.584-.011-4.85-.069c-1.366-.062-2.633-.336-3.608-1.311-.975-.975-1.249-2.242-1.311-3.608C2.175 15.747 2.163 15.368 2.163 12s.012-3.584.07-4.85c.062-1.366.336-2.633 1.311-3.608.975-.975 2.242-1.249 3.608-1.311C8.416 2.175 8.796 2.163 12 2.163zm0 1.802c-3.142 0-3.516.012-4.756.068-1.014.047-1.565.215-1.93.358-.485.188-.832.413-1.196.777-.364.364-.589.711-.777 1.196-.143.366-.311.916-.358 1.93-.056 1.24-.068 1.614-.068 4.756 0 3.142.012 3.516.068 4.756.047 1.014.215 1.565.358 1.93.188.485.413.832.777 1.196.364.364.711.589 1.196.777.366.143.916.311 1.93.358 1.24.056 1.614.068 4.756.068 3.142 0 3.516-.012 4.756-.068 1.014-.047 1.565-.215 1.93-.358.485-.188.832-.413 1.196-.777.364-.364.589-.711.777-1.196.143-.366.311-.916.358-1.93.056-1.24.068-1.614.068-4.756 0-3.142-.012-3.516-.068-4.756-.047-1.014-.215-1.565-.358-1.93-.188-.485-.413-.832-.777-1.196-.364-.364-.711-.589-1.196-.777-.366-.143-.916-.311-1.93-.358-1.24-.056-1.614-.068-4.756-.068zM12 6.865a5.135 5.135 0 100 10.27 5.135 5.135 0 000-10.27zm0 8.468a3.333 3.333 0 110-6.666 3.333 3.333 0 010 6.666zm6.538-8.671a1.2 1.2 0 11-2.4 0 1.2 1.2 0 012.4 0z"
            ></path></svg
          >
        </a>
      </div>
      <p class="m-0 font-semibold tracking-wider" style="font-family: var(--font-display); color: var(--color-accent);">
        Nerdy Layers 3D
      </p>
    </footer>
  </body>
</html>
